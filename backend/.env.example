# MongoDB Atlas Connection String
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/cadet-connection-portal?retryWrites=true&w=majority

# JWT Secret (use a strong random string)
JWT_SECRET=your_super_secret_jwt_key_change_this

# Server Port
PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=https://cadet-connection-portal.vercel.app

# Node Environment
NODE_ENV=production
